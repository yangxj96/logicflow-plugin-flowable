{
    "name": "@yangxj96/logicflow-flowable",
    "version": "0.0.3-dev.20260315.0",
    "description": "基于 LogicFlow 的 Flowable / BPMN 2.0 流程建模与可视化扩展插件",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/yangxj96/logicflow-flowable.git"
    },
    "bugs": {
        "url": "https://github.com/yangxj96/logicflow-flowable/issues"
    },
    "homepage": "https://github.com/yangxj96/logicflow-flowable#readme",
    "keywords": [
        "bpmn",
        "flowable",
        "logicflow",
        "workflow",
        "process-designer"
    ],
    "author": {
        "name": "yangxj96",
        "url": "https://github.com/yangxj96"
    },
    "license": "Apache-2.0",
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./dist/index.css": "./dist/index.css"
    },
    "files": [
        "dist",
        "types",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "prepublishOnly": "npm run build",
        "dev": "tsup --watch",
        "format": "prettier --write ./src",
        "format:check": "prettier --check ./src"
    },
    "peerDependencies": {
        "@logicflow/core": "^2.1.11",
        "@logicflow/extension": "^2.1.11",
        "element-plus": "^2.13.5",
        "vue": "^3.5.30"
    },
    "devDependencies": {
        "@logicflow/core": "^2.1.11",
        "@logicflow/extension": "^2.1.11",
        "prettier": "^3.7.4",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "xml-formatter": "^3.7.0"
    }
}
